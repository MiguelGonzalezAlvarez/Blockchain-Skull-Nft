# Environment Variables

# Blockchain Networks
VITE_DEFAULT_NETWORK=97
VITE_RPC_URL=http://localhost:7545

# Alchemy API (for mainnet support)
VITE_ALCHEMY_KEY=your_alchemy_key_here

# Smart Contract Address (deployed)
VITE_CONTRACT_ADDRESS=0x...

# API Keys (optional)
VITE_ETHERSCAN_API_KEY=your_etherscan_key
VITE_COINMARKETCAP_API_KEY=your_coinmarketcap_key
